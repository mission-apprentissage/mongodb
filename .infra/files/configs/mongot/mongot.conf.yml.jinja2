# Config mongot colocalisé sur le nœud mongod local (rs-{{ env_type }}).
#
# net.tls.mode: requireTLS est actif sur ce cluster (mongod.conf.step-2.jinja2), y compris pour
# les connexions locales : la connexion syncSource ci-dessous doit donc passer par TLS même en
# loopback. CAFile réutilise la CA publique du cluster (mongod.conf.step-1/2.jinja2) pour vérifier
# le certificat serveur présenté par mongod.
#
# ATTENTION : le certificat serveur mongod est émis pour {{ dns_name }}, pas pour 127.0.0.1 — la
# vérification du hostname échouera telle quelle. À valider/ajuster contre la configuration
# effective de mongot 1.70.1 (cf. `/opt/mongot/bin/mongot --config /dev/null --help` ou le
# config.default.yml de l'image mongodb/mongodb-community-search:1.70.1 cité dans le handoff) avant
# le premier déploiement réel : soit une option de type tlsAllowInvalidHostnames côté
# syncSource.replicaSet.tls, soit connexion via {{ dns_name }} avec résolution forcée vers
# 127.0.0.1 (entrée /etc/hosts dédiée).

syncSource:
  replicaSet:
    hostAndPort: "127.0.0.1:27017"
    scramAuth:
      username: mongotUser
      authSource: admin
      passwordFile: /etc/mongot/secrets/passwordFile
      tls:
        enabled: true
        CAFile: /mnt/data/mongodb-ca.pem
  replicationReader:
    readPreference: primaryPreferred

storage:
  dataPath: /mnt/data/mongot

server:
  wireproto:
    address: 127.0.0.1
    port: 27028

metrics:
  enabled: true
  # 0.0.0.0 (comme bindIpAll côté mongod) : le scrape Prometheus se fait depuis le serveur de
  # monitoring, pas en local. L'accès est restreint au niveau nftables (repo infra, ip saddr
  # $MONITORING tcp dport 9946 accept), pas par ce binding.
  address: 0.0.0.0
  port: 9946

healthCheck:
  address: 127.0.0.1
  port: 8080

systemLog:
  path: /var/log/mongot/mongot.log
  logAppend: true
