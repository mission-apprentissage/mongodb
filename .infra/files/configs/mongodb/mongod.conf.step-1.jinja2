net:
  bindIpAll: true
  tls:
    mode: requireTLS

    # Certificat serveur signé par la CA publique (présenté aux clients)
    certificateKeyFile: /mnt/data/mongodb.pem

    # CA publique : utilisée pour vérifier les certificats serveurs
    CAFile: /mnt/data/mongodb-ca.pem

    # Certificat client signé par la CA privée (présenté aux nœuds de la grappe)
    clusterFile: /mnt/data/mongodb-cluster.pem

    # CA privée : utilisée pour vérifier les certificats clients
    clusterCAFile: /mnt/data/mongodb-cluster-ca.pem

    disabledProtocols: TLS1_0,TLS1_1
    allowConnectionsWithoutCertificates: true

    clusterAuthX509:
      extensionValue: rs-{{ env_type }}

systemLog:
  path: /var/log/mongodb/mongod.log
  logAppend: true
  logRotate: reopen
  destination: file

operationProfiling:
  mode: slowOp
  slowOpThresholdMs: 500

security:
  clusterAuthMode: x509
  authorization: enabled
  javascriptEnabled: false

storage:
  dbPath: /mnt/data/db
  directoryPerDB: true
  oplogMinRetentionHours: 168
{% if mongot_enable | default(false) | bool %}

setParameter:
  mongotHost: "127.0.0.1:27028"
  searchIndexManagementHostAndPort: "127.0.0.1:27028"
  searchTLSMode: disabled
  skipAuthenticationToSearchIndexManagementServer: false
  useGrpcForSearch: true
{% endif %}
